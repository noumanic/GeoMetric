# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/
.Python

# Virtual environments
.venv/
venv/
env/
ENV/
.geovenv/

# Data files (large — track with Git LFS or exclude entirely)
data/raw/**/*.zip
data/raw/**/*.tar.gz
data/raw/**/*.nc
data/raw/**/airports.dat
data/raw/**/routes.dat
data/raw/**/owid-co2-data.csv
data/raw/**/world_population.csv
data/cache/

# Keep marker files in raw data
!data/raw/**/.downloaded

# Outputs (regeneratable — optionally exclude)
outputs/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDEs / editors
.vscode/
.idea/
*.swp
*.swo

# Environment variables
.env
.env.local
.env.example

# Logs
*.log
logs/
flake8_output.txt

# Report drafts
report/drafts/

